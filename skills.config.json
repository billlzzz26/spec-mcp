      "scaffold", "scaffolding", "implementation", "strategy", "context",
      "feature", "features", "smart", "system", "systems", "design",
      "development", "test", "testing"
    ]
  },

  "categories": {
    "description": "Rule-based category detection — ลำดับสำคัญ: match แรกชนะ",
    "rules": [
      {
        "name": "security",
