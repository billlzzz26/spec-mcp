  },

  "tagStopwords": {
    "description": "กรอง token ออกจาก tag derivation",
    "tokens": [
      "pro", "expert", "patterns", "pattern", "workflow", "workflows",
      "templates", "template", "toolkit", "tools", "tool", "project", "projects",
